4a977763c5efd.poster.avif?t=1770220532\" width=48 height=92 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/109bbb7c169c0fe0bda4a977763c5efd.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/109bbb7c169c0fe0bda4a977763c5efd.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/7fbeb84310ae98fd2ef18289537f6fcf.poster.avif?t=1770220532\" width=32 height=78 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/7fbeb84310ae98fd2ef18289537f6fcf.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/7fbeb84310ae98fd2ef18289537f6fcf.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/52dc40f0d2e4c408836092b5d1691837.poster.avif?t=1770220532\" width=53 height=88 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/52dc40f0d2e4c408836092b5d1691837.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/576e271e5674fba7ab59949819888539.poster.avif?t=1770220532\" width=50 height=88 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/576e271e5674fba7ab59949819888539.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/576e271e5674fba7ab59949819888539.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/17360a0ab52aee2071a6b2988b50800d.poster.avif?t=1770220532\" width=42 height=88 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/17360a0ab52aee2071a6b2988b50800d.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/17360a0ab52aee2071a6b2988b50800d.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d88dec6c5ef8b8ec9b9ca7fd55b963ec.poster.avif?t=1770220532\" width=42 height=86 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d88dec6c5ef8b8ec9b9ca7fd55b963ec.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d88dec6c5ef8b8ec9b9ca7fd55b963ec.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/0b53dd894fc1eef2c4e5e26ab499bf1c.poster.avif?t=1770220532\" width=52 height=80 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/0b53dd894fc1eef2c4e5e26ab499bf1c.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/0b53dd894fc1eef2c4e5e26ab499bf1c.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/8bdf2a97fdf4615564725b3b82e9c508.poster.avif?t=1770220532\" width=44 height=74 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/8bdf2a97fdf4615564725b3b82e9c508.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/8bdf2a97fdf4615564725b3b82e9c508.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline crossorigin=\"anonymous\" poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/f5be5457e7e4f471c8d071e11c76bd82.poster.avif?t=1770220532\" width=42 height=92 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/f5be5457e7e4f471c8d071e11c76bd82.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"></video></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"></p><p class=\"bb_paragraph\" style=\"text-align: center\">Once someone joins your party, you can <strong>switch between party members at any time</strong> and take direct control of them. Whether you turn these characters into <strong>allies, friends, partners</strong>, or even <strong>enemies</strong> (or choose to avoid them entirely) is up to you!</p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/347f796e2632f9b5eb2e6f2af465ddee.avif?t=1770220532\" width=600 height=360 /></span></p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/b7aab646a4b977632fec4dd2bf42ab3e.avif?t=1770220532\" width=500 height=92 /></span></h2><p class=\"bb_paragraph\" style=\"text-align: center\"> <strong>Forlorn Memories</strong> uses two different graphic styles, the anime-inspired <strong>Chibi style (SD)</strong> used for the exploration part and a more detailed, <strong>non-chibi-style </strong>graphic style for the game's battle scenarios and story sequences designed by talents such as <strong>Yoshitomo Ikawa</strong> (Mistwalker).</p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/94a7814381f25aacafbebbda2fe18b47.poster.avif?t=1770220532\" width=672 height=378 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/94a7814381f25aacafbebbda2fe18b47.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/94a7814381f25aacafbebbda2fe18b47.mp4?t=1770220532\" type=\"video/mp4\"></video></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/b521c665a2d3e836f4be4f608d31df4b.avif?t=1770220532\" width=500 height=92 /></span></h2><p class=\"bb_paragraph\" > When words fall flat and conflict escalates into combat, experience an accessible yet deep combat system where you identify and exploit your foes’ weaknesses.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" ><strong>Key Features:</strong></h2><ul class=\"bb_ul\"><li><p class=\"bb_paragraph\" >Elementtypes with clear strengths and weaknesses.</p></li><li><p class=\"bb_paragraph\" >Weakpoint targeting<strong>:</strong> aim at specific limbs to disarm foes and restrict their moveset and ability pool.</p></li><li><p class=\"bb_paragraph\" >Up to 3 active party members.</p></li><li><p class=\"bb_paragraph\" >Swap party members anytime, <strong>overworld</strong> and <strong>mid-battle.</strong></p></li><li><p class=\"bb_paragraph\" >Character-specific Ultimate skills.</p></li><li><p class=\"bb_paragraph\" >Mounted combat (horseback).</p></li><li><p class=\"bb_paragraph\" >Summon captured monsters (<strong>Beasts of Yhag</strong> &amp; <strong>Spirits</strong>) during battle.</p></li></ul><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/f27af531842e32f89f7bf2248b3b34ac.avif?t=1770220532\" width=500 height=92 /></span> </h2><p class=\"bb_paragraph\" > </p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d64194e5550ce9bac77800d600c0a3ff.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" >Detailed interactions and relationships between playable characters and NPCs. This can even optionally lead to friendships, romantic relationships, marriages and other peaceful couple activities.</p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/427684eae812e92f2973e4454736f86b.avif?t=1770220532\" width=500 height=92 /></span> </h2><p class=\"bb_paragraph\" style=\"text-align: center\"> <span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/a5c7783d623690846c494fb83a57f3e7.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"></p><p class=\"bb_paragraph\" >Step into Legica, a vast, sprawling world filled with forgotten history and hidden truths. Every region holds unique lands, factions, and cultures shaped by conflict and ambition. Explore its wild frontiers, fight in its wars, or carve out a quiet life of your own as you run, dash, swim, dive, grind on rails, set sail, fly, drive, and ride across an expansive fantasy realm teeming with captivating events and stories.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/4c0733eff3e8909bc99ba4c0e28fecca.avif?t=1770220532\" width=500 height=92 /></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/2574301605ab6f6a995f1fc35abc3634.avif?t=1770220532\" width=1560 height=877 /></span>Legica doesn’t just threaten you with its inhabitants. Blizzards, heatwaves, and hostile terrain demand careful planning, so bring the right clothing and equipment and choose your route wisely to overcome environmental hazards.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d07490ca35d23a6dae91eedee49d530f.avif?t=1770220532\" width=500 height=92 /></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d6ab60904089b1a879459fc3b228fa16.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" >Venture into forgotten depths where ancient ruins hide secrets, treasure, and horrors best left undisturbed.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/fa09aa591852d81a51c1afc6f35f584f.avif?t=1770220532\" width=500 height=92 /></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/e73e5ede242ebc762b6912b9fc1a2a5d.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" >Legica is shaped by rival factions, each driven by its own traditions and agendas. Forge alliances, keep your distance, or stand against them. Your choice defines your journey.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/9f8566525834c4b013c9f622d6ff870c.avif?t=1770220532\" width=500 height=92 /></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/801d0d44fd93600ff991e10550ddbd1b.avif?t=1770220532\" width=1560 height=877 /></span>Your choices have consequences. Some are immediate, others only reveal themselves later in your journey. They can even shift the balance between factions, for example if you trade too much with one group and help them gain more resources and better equipment.</p><p class=\"bb_paragraph\" >In extreme cases, your actions can go so far that even former companions may end up standing in your way.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" style=\"text-align: center\"></p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/b4fa00d98e31930f73b3007513293a35.avif?t=1770220532\" width=500 height=92 /></span></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/1639696c4c76e2f0443a656ab4e9ab88.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" > Mix potions and medicines, dig for buried treasure, craft armour, clothing and weapons, catch bugs, mine ores, go fishing, cook various foods and create and repair your own automata. How you achieve your goals is up to you.</p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/f99fa01d47895924977c184e12322639.avif?t=1770220532\" width=500 height=92 /></span></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/3cd26bf5780bbf04febedb7efbfea5db.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" > Give abandoned pets a new home. Adopt pets like cats, dogs, horses and more. (Yes, you can pet them and name them!) </p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/c0d7f8f9966d9eab740fcf027d517ca6.avif?t=1770220532\" width=500 height=92 /></span></h2><p class=\"bb_paragraph\" ><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/79e2a2871fe6b161e00b0559ed8a8628.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" > Grow different types of plants. Gift them to NPCs, sell them, use them as a crafting ingredient or use some of them in battle. Or you can grow tiny sprout spirit creatures that can help you on your journey and evolve over time to learn new skills.</p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/c1794121ec842593671a7fec0125da04.avif?t=1770220532\" width=500 height=92 /></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/9ae9e7ac893353495c46b27b69c6f063.avif?t=1770220532\" width=1560 height=877 /></span></p><p class=\"bb_paragraph\" >The world of <strong>Legica</strong> is haunted by a phenomenon known simply as the <strong>Yhag Curse</strong>. It slowly but steadily transforms any living being that spends too long near the so-called <strong>Beasts of Yhag</strong>. The first signs are faint, glyph-like markings spreading across the body, followed by changes to skin, eyes, and hair. Over time, the curse causes severe physical and mental distortion, until very little of the victim’s former self remains.</p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" >Rumors speak of rare individuals who resisted the curse, and who were even able to tame these beasts. They now seek to uncover the origin of the creatures, and the truth behind the curse.</p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/29bb5247ccb83e71f1d9b0f78e4f0af3.avif?t=1770220532\" width=500 height=92 /></span></h2><p class=\"bb_paragraph\" > Conquer the skies with your own airship and destroy enemies with your mech in the game's fully optional Shoot 'em up and Top-down Shooter sections.</p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/608e803ade2233f5d15fbd11cb9b05de.avif?t=1770220532\" width=500 height=92 /></span> </h2><p class=\"bb_paragraph\" > Starring Caitlin Glass, Alan Lee, Xanthe Huynh, Lindsey Vega, Deneen Melody, A.J. Beckles, Kristen McGuire, June Yoon, Vanille Velasquez, Anairis Quinones, Chris Okawa, Sarah Anne Williams and many more.</p><p class=\"bb_paragraph\" ></p><h2 class=\"bb_tag\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/f0d2e8173711421469245cc2c0f37ab0.avif?t=1770220532\" width=500 height=92 /></span></h2><p class=\"bb_paragraph\" > Original soundtrack composed by Alec Shea, Bryan Valenzuela, Morgan Cosseron, Jeremiah George, Raúl Sangonzalo, Dale North and more with vocals performed by Emi Evans (<i>NieR, Terra Battle, Dark Souls</i>) and Nami Nakagawa (<i>NieR, Demon Slayer</i>). </p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/a162fa5e79c382a503b1f2fd6eb5ef3a.webp?t=1770220532\" width=600 height=39 /></span></p><p class=\"bb_paragraph\" ></p><p class=\"bb_paragraph\" style=\"text-align: center\"><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/17cac08c0eeb0a301a37aa0c84f4e3fa.avif?t=1770220532\" width=600 height=374 /></span></p><p class=\"bb_paragraph\" style=\"text-align: center\"><i>Please keep in mind that the game is still in development and the footage shown is not final.</i></p>",
