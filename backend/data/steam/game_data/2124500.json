2\" width=46 height=88 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/362649908852c561c7b341122adc77be.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/362649908852c561c7b341122adc77be.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/4dcfa41124ce068f46b37a544baab402.poster.avif?t=1770220532\" width=42 height=86 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/4dcfa41124ce068f46b37a544baab402.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/4dcfa41124ce068f46b37a544baab402.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d1d5845092e5b00fc7e58d72c91d14b8.poster.avif?t=1770220532\" width=44 height=80 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d1d5845092e5b00fc7e58d72c91d14b8.webm?t=1770220532\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/d1d5845092e5b00fc7e58d72c91d14b8.mp4?t=1770220532\" type=\"video/mp4\"></video></span><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/ac4d9de515c9ef91a15726139a5db48c.poster.avif?t=1770220532\" width=38 height=86 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2124500/extras/ac4d9de515c9ef91a15726139a5db