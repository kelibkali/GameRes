5c23c62e2aa8a28ad.webm?t=1730099778\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/8e470340444c87f5c23c62e2aa8a28ad.mp4?t=1730099778\" type=\"video/mp4\"></video></span><br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/37e93fa372b3fb2b1f9618c5640e0946.poster.avif?t=1730099778\" width=600 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/37e93fa372b3fb2b1f9618c5640e0946.webm?t=1730099778\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/37e93fa372b3fb2b1f9618c5640e0946.mp4?t=1730099778\" type=\"video/mp4\"></video></span><br><br>When placing panels, be careful to avoid encountering natural enemies such as bears and foxes.<br>To avoid encountering natural enemies , place panels while keeping an eye on the direction in which they are moving.<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/2a1cba22d7de88f0a3ac1a9125aedf94.poster.avif?t=1730099778\" width=600 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/2a1cba22d7de88f0a3ac1a9125aedf94.webm?t=1730099778\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/2a1cba22d7de88f0a3ac1a9125aedf94.mp4?t=1730099778\" type=\"video/mp4\"></video></span><br><br><br><span class=\"bb_img_ctn\"><img class=\"bb_img\" src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/b4683665a74ba7749e96336a8fe60cb4.webp?t=1730099778\" width=16 height=16 /></span> <strong>Gathering Friends</strong><br>As the game progresses, you will find your straggler friends.<br>You can also play with your fellow rabbits by giving them carrots that you pick up on stage, and they can switch places with the pink rabbit.<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/48a1e118663447a1d40f2db3d7cd1abc.poster.avif?t=1730099778\" width=600 height=250 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/48a1e118663447a1d40f2db3d7cd1abc.webm?t=1730099778\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/2341900/extras/48a1e118663447a1d40f2db3d7cd1abc.mp4?t=1730099778\" type=\"video/mp4\"></video></span>",
