/apps/3301760/extras/2b68054d4db54d26fb3e1ed27ef1b7a1.webm?t=1751022995\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3301760/extras/2b68054d4db54d26fb3e1ed27ef1b7a1.mp4?t=1751022995\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >揭开真相</h2><br>谁派你们来的？这个村庄发生了什么事？你真的是孤身一人吗？<br>在寻找答案的过程中发现独特的环境。<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3301760/extras/c45a32281f4f461e362faa6febab0cf9.poster.avif?t=1751022995\" width=600 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3301760/extras/c45a32281f4f461e362faa6febab0cf9.webm?t=1751022995\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3301760/extras/c45a32281f4f461e362faa6febab0cf9.mp4?t=1751022995\" type=\"video/mp4\"></video></span><h2 class=\"bb_tag\" >探索过去</h2><br>解开谜题、寻找关键物品并与环境互动，从而进入新的地方。<br>寻找前世的遗迹，弄清这里发生了什么。<br><br><span class=\"bb_img_ctn\"><video class=\"bb_img\" autoplay muted loop playsinline poster=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3301760/extras/b5aed14af8fc9984c1d6401149c09abf.poster.avif?t=1751022995\" width=600 height=300 ><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3301760/extras/b5aed14af8fc9984c1d6401149c09abf.webm?t=1751022995\" type=\"video/webm; codecs=vp9\"><source src=\"https://shared.akamai.steamstatic.com/store_item_assets/steam/apps/3301760/extras/b5aed14af8fc9984c1d6401149c09abf.mp4?t=1751022995\" type=\"video/mp4\"></video></span>",
